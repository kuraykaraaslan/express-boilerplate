# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APPLICATION_NAME=MyApp
NEXT_PUBLIC_APPLICATION_HOST=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
SYSTEM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_boilerplate?schema=system
TENANT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_boilerplate?schema=tenant

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# Tenancy
# ─────────────────────────────────────────────
# "domain" → subdomain/custom domain based (default)
# "path"   → path based  (e.g. example.com/t/{tenantId}/...)
TENANCY_MODE=domain

# Used in domain mode: subdomain that maps to the system panel
TENANT_DEFAULT_SUBDOMAIN=system
# Base domain for wildcard subdomains (e.g. tenant1.example.com)
TENANT_WILDCARD_DOMAIN=example.com
NEXT_PUBLIC_TENANT_WILDCARD_DOMAIN=example.com

# Used in path mode: URL prefix before tenantId  (default: "t")
# e.g. TENANT_PATH_PREFIX=t  →  /t/{tenantId}/dashboard
TENANT_PATH_PREFIX=t

# Domain lookup cache TTL in seconds (default: 300)
TENANT_CACHE_TTL=300

# ─────────────────────────────────────────────
# Mail
# ─────────────────────────────────────────────
# Provider: "smtp" | "mailgun" | "ses"
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@example.com

# SMTP
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# SMTP (alternative keys)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=EU

# AWS SES
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1

# ─────────────────────────────────────────────
# Storage (S3 / compatible)
# ─────────────────────────────────────────────
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1

# ─────────────────────────────────────────────
# Web Push / VAPID
# ─────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@example.com

# ─────────────────────────────────────────────
# Auth Secrets (REQUIRED — change all values in production)
# ─────────────────────────────────────────────
ACCESS_TOKEN_SECRET=dev-access-token-secret-change-in-production
REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-in-production
CSRF_SECRET=dev-csrf-secret-change-in-production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Cron (shared secret for HTTP cron endpoint)
# ─────────────────────────────────────────────
CRON_SECRET=dev-cron-secret-change-in-production

# ─────────────────────────────────────────────
# Editor
# ─────────────────────────────────────────────
NEXT_PUBLIC_TINYMCE_API_KEY=
