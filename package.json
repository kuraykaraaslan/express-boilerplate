{
  "name": "express-boilerplate",
  "version": "1.0.6",
  "description": "Express based API boilerplate",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn -r tsconfig-paths/register server.ts",
    "build": "tsc",
    "lint:check": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "vercel-build": "npm run build",
    "test": "jest --detectOpenHandles --forceExit --passWithNoTests",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "typeorm:migrate": "npm run typeorm migration:run -- -d ./src/shared/libs/typeorm/index.ts",
    "typeorm:generate": "npm run typeorm -- -d src/shared/libs/typeorm/index.ts migration:generate ./migrations/$npm_config_name",
    "typeorm:revert": "npm run typeorm -- -d ./src/shared/libs/typeorm/index.ts migration:revert"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuraykaraaslan/express-boilerplate.git"
  },
  "author": "Kuray Karaaslan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kuraykaraaslan/express-boilerplate/issues"
  },
  "homepage": "https://github.com/kuraykaraaslan/express-boilerplate#readme",
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/csurf": "^1.11.5",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.1",
    "@types/geoip-lite": "^1.4.4",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@typescript/native-preview": "^7.0.0-dev.20250526.1",
    "dotenv": "^16.5.0",
    "eslint": "^9.26.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "express": "^5.1.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "3.5.3",
    "prisma": "^6.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/client": "^6.7.0",
    "@sendgrid/mail": "^8.1.5",
    "@simplewebauthn/server": "^13.3.0",
    "@types/web-push": "^3.6.4",
    "axios": "^1.9.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.0",
    "bullmq": "^5.52.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "csurf": "^1.10.0",
    "cuid": "^3.0.0",
    "currency-codes-ts": "^3.0.0",
    "ejs": "^3.1.10",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.5",
    "geoip-lite": "^1.4.10",
    "google-libphonenumber": "^3.2.40",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "nodemon": "^3.1.10",
    "otplib": "^12.0.1",
    "pg": "^8.16.0",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.4.0",
    "twilio": "^5.5.2",
    "typeorm": "^0.3.29",
    "uuid": "^11.1.0",
    "vitest": "^4.1.6",
    "web-push": "^3.6.7",
    "winston": "^3.17.0"
  },
  "keywords": [],
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "_moduleAliases": {
    "@": "./dist"
  }
}
