{
    "builds": [
      {
        "src": "dist/index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/dist/index.js"
      }
    ],
    "crons": [
      {
        "path": "/api/v1/cron/report",
        "schedule": "0 0 * * *"
      }
    ]
  }